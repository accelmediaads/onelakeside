# Copy to .env.local for local dev, and set the same key in Netlify:
# Site settings → Environment variables.
#
# Follow Up Boss API key — server-side only (used by app/api/lead/route.ts to
# create CRM leads). Without it, form submits still send the Web3Forms email
# notification, but no FUB record is created.
FUB_API_KEY=
